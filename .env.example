# ── Auth (GitHub OAuth App) ──
# Create at: https://github.com/settings/developers > New OAuth App
# Homepage URL: https://your-app.vercel.app
# Callback URL:  https://your-app.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-app.vercel.app

# Comma-separated GitHub usernames allowed to log in
ALLOWED_GITHUB_USERS=matthewjohnson,jamoy

# ── Anthropic (AI processing) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel KV (auto-set when you add KV from Vercel dashboard) ──
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Discourse (Command Legacy) ──
DISCOURSE_URL=https://your-command-legacy.com
DISCOURSE_API_KEY=
DISCOURSE_API_USERNAME=system
DISCOURSE_CATEGORY_ID=1

# ── Cron Security ──
CRON_SECRET=
